{
  "_comment": "Конфігурація DRC Benchmark. Змініть параметри та запустіть main.exe",

  "output": {
    "save_to_file": true,
    "filename": "results.csv",
    "print_to_console": true,
    "format": "both"
  },

  "topology": {
    "seed": 42,
    "poly_min_size": 20.0,
    "poly_max_size": 150.0,
    "layers": 3,

    "polygon_counts": [1000, 3000, 5000, 10000],

    "densities": [
      {
        "name": "Низька",
        "id": "LOW",
        "world_width":  50000.0,
        "world_height": 50000.0,
        "enabled": true
      },
      {
        "name": "Середня",
        "id": "MEDIUM",
        "world_width":  10000.0,
        "world_height": 10000.0,
        "enabled": true
      },
      {
        "name": "Висока",
        "id": "HIGH",
        "world_width":  3000.0,
        "world_height": 3000.0,
        "enabled": true
      }
    ]
  },

  "check": {
    "min_distance": 20.0
  },

  "algorithms": {
    "runs_per_measurement": 3,

    "distance_check": {
      "cpu_naive":          { "enabled": true,  "label": "CPU Naive"          },
      "cpu_sweepline":      { "enabled": true,  "label": "CPU Sweep-line"     },
      "cpu_parallel":       { "enabled": true,  "label": "CPU Parallel (OMP)" },
      "cpu_opt_parallel":   { "enabled": true,  "label": "CPU Opt.Parallel"   },
      "gpu_bruteforce":     { "enabled": true,  "label": "GPU Brute-force"    },
      "gpu_optimized":      { "enabled": true,  "label": "GPU Optimized"      }
    },

    "polygon_clipping": {
      "cpu_naive":          { "enabled": true,  "label": "CPU Naive"          },
      "cpu_sweepline":      { "enabled": true,  "label": "CPU Sweep-line"     },
      "cpu_parallel":       { "enabled": true,  "label": "CPU Parallel (OMP)" },
      "cpu_opt_parallel":   { "enabled": true,  "label": "CPU Opt.Parallel"   },
      "gpu_bruteforce":     { "enabled": true,  "label": "GPU Brute-force"    },
      "gpu_optimized":      { "enabled": true,  "label": "GPU Optimized"      }
    }
  }
}
